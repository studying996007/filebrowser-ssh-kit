# filebrowser-ssh-kit configuration. Copy to .env and edit. (.env is gitignored.)

# Identity tag written into the X-FB-Server header; the desktop launcher uses it
# to confirm it reached the right server. It MUST be unique per server, otherwise a
# client could silently reuse a tunnel to the wrong machine.
# Leave BLANK to auto-use this machine's hostname (recommended — guarantees uniqueness).
FB_SERVER_ID=

# Directory filebrowser serves as its root. Created automatically by start.sh if it does not exist.
FB_ROOT=$HOME/files

# Ports: filebrowser listens on FB_PORT (internal only); the inject proxy listens
# on PX_PORT (the port you tunnel to).
FB_PORT=8090
PX_PORT=8080

# filebrowser binary and database locations.
FB_BIN=$HOME/.local/bin/filebrowser
FB_DB=$HOME/filebrowser.db

# ---- "Copy path" button (optional) ----
# Absolute server-path prefix the button shows. Empty = show the in-app path only.
#   example: FB_PATH_ROOT=/data/files
FB_PATH_ROOT=

# Optional per-account prefixes, as JSON. Empty = every user gets FB_PATH_ROOT.
# This file is sourced as a shell script, so the JSON MUST be wrapped in single quotes —
# without them the shell strips the inner double-quotes and the value becomes invalid JSON
# (the proxy then silently ignores it).
#   example: FB_PATH_MAP='{"alice":"/data/alice","bob":"/data"}'
FB_PATH_MAP=

# ---- Admin account (used by server/init-admin.sh) ----
# Minimum password length, written into filebrowser's own config. Matches filebrowser's
# own built-in default of 12; only lower it if you really must. filebrowser also rejects
# well-known weak passwords regardless of this value.
FB_MIN_PW_LEN=12
# Optional: set the admin password non-interactively for server/init-admin.sh
# (otherwise it prompts). Prefer exporting it in your shell over committing it here.
#FB_ADMIN_PASSWORD=

# ---- Advanced (optional; sensible defaults shown) ----
# Watchdog restart backoff in seconds: first retry after KA_BASE, doubling to KA_CAP.
#KA_BASE=15
#KA_CAP=120
# Seconds start.sh waits for the single-instance watchdog lock to free before failing.
#FB_LOCK_WAIT=15
# Log locations (move these if $HOME is on a slow or full filesystem).
#FB_LOG=$HOME/filebrowser.log
#PX_LOG=$HOME/filebrowser-proxy.log
#KA_LOG=$HOME/filebrowser-keepalive.log
